# Hire Intelligence — Environment Variables
# Copy this file to .env.local and fill in the values.

# Required: Groq API key for AI-powered CV analysis (Llama 3.3 70B Versatile)
# Get yours at https://console.groq.com/keys — free tier is sufficient for testing.
GROQ_API_KEY=your_groq_api_key_here

# Database: Supabase project credentials (Settings → API in your Supabase dashboard)
# If left blank, the app falls back to browser localStorage.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# Optional: protect the /api/keep-alive cron endpoint (see vercel.json).
# If set, Vercel Cron sends it automatically as a Bearer token. Leave blank to
# keep the endpoint open (the query is read-only and harmless).
# CRON_SECRET=some_long_random_string

# Optional: send candidate emails directly from the server (no "open a tab").
# Uses a Gmail App Password (Google Account → Security → 2-Step Verification →
# App passwords). When unset, the app falls back to Gmail web compose / mailto.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=you@gmail.com
# SMTP_PASS=your_16_char_app_password
# SMTP_FROM=Your Name <you@gmail.com>
