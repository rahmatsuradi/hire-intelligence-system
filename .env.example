# Hire Intelligence — Environment Variables
# Copy this file to .env.local and fill in the values.

# Required: Groq API key for AI-powered CV analysis (Llama 3.3 70B Versatile)
# Get yours at https://console.groq.com/keys — free tier is sufficient for testing.
GROQ_API_KEY=your_groq_api_key_here

# Database: Supabase project credentials (Settings → API in your Supabase dashboard)
# If left blank, the app falls back to browser localStorage.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# Server-only: Supabase SERVICE ROLE (secret) key — powers the public apply flow
# (/api/apply) which writes without a user session under authenticated-only RLS.
# Settings → API Keys → secret key (sb_secret_...). NEVER prefix with NEXT_PUBLIC_,
# never commit, never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_key
